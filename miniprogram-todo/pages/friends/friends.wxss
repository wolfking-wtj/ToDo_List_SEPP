/* pages/friends/friends.wxss */
.container {
  min-height: 100vh;
  background: var(--bg-main);
  padding: 32rpx 32rpx 200rpx;
}

.search-bar {
  margin-bottom: 32rpx;
}

.search-inner {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 18rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
  gap: 16rpx;
}

.search-inner:focus-within {
  border-color: var(--primary-light);
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.08);
}

.search-icon-text {
  font-size: 32rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.4;
}

.search-placeholder {
  color: var(--text-muted);
  font-size: 28rpx;
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-muted);
  width: 44rpx;
  height: 44rpx;
  display: none;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--border);
}

.search-clear.show {
  display: flex;
}

.friends-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.friend-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  gap: 20rpx;
}

.friend-item:active {
  transform: scale(0.985);
  background: var(--primary-light);
}

.friend-avatar {
  position: relative;
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
}

.avatar-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.avatar-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.friend-info {
  flex: 1;
  min-width: 0;
}

.friend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.friend-status {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.friend-action {
  flex-shrink: 0;
}

.action-icon {
  font-size: 32rpx;
  color: var(--text-muted);
}

.task-btn {
  padding: 16rpx;
  border-radius: 50%;
  background: var(--primary-light);
  transition: all 0.2s ease;
}

.task-btn:active {
  background: var(--primary);
  transform: scale(0.9);
}

.task-btn .action-icon {
  color: var(--primary);
}

.pending-tasks-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff3cd;
  border: 2rpx solid #ffe69c;
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #856404;
  font-weight: 500;
}

.view-btn {
  padding: 8rpx 20rpx;
  background: #856404;
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.add-friend-btn {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 24rpx 48rpx;
  border-radius: var(--radius-xl);
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
  z-index: 999;
}

.add-friend-btn:active {
  transform: translateX(-50%) scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.add-icon {
  font-size: 32rpx;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}

.add-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.heatmap-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.heatmap-content {
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.heatmap-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.heatmap-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.heatmap-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  object-fit: cover;
}

.heatmap-avatar-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
}

.heatmap-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.heatmap-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.heatmap-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: var(--bg-main);
  border-radius: var(--radius-lg);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.heatmap-calendar {
  margin-bottom: 32rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.calendar-month {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-arrows {
  display: flex;
  gap: 16rpx;
}

.arrow-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-main);
  border-radius: 8rpx;
  position: relative;
  transition: all 0.2s ease;
}

.calendar-day.has-data {
  cursor: pointer;
}

.calendar-day.has-data:active {
  transform: scale(0.95);
}

.intensity-0 {
  background: #e0e0e0;
}

.intensity-1 {
  background: #c8e6c9;
}

.intensity-2 {
  background: #a5d6a7;
}

.intensity-3 {
  background: #81c784;
}

.intensity-4 {
  background: #66bb6a;
}

.day-weekday {
  font-size: 18rpx;
  color: var(--text-muted);
  margin-bottom: 2rpx;
}

.day-date {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.day-count {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.heatmap-legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.legend-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.add-friend-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.add-friend-content {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

.add-friend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.add-friend-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.add-friend-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.add-friend-search {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.add-friend-results {
  padding: 24rpx 32rpx;
}

.empty-results {
  padding: 64rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-item {
  background: var(--bg-main);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.user-item:active {
  transform: scale(0.985);
  background: var(--primary-light);
}

.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-icon {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.user-meta {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
}

.user-level {
  color: var(--primary);
  font-weight: 500;
}

.user-points {
  color: var(--text-secondary);
}

.user-action {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.friend-tag {
  padding: 8rpx 16rpx;
  background: var(--success-light);
  color: var(--success);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.add-btn {
  padding: 8rpx 16rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.user-email {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 80rpx;
}

.test-btn {
  margin: 32rpx;
  padding: 24rpx;
  background: #f0f0f0;
  border-radius: var(--radius-lg);
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1002;
}

.post-task-modal {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  width: 90%;
  max-width: 700rpx;
  height: auto;
  max-height: 85vh;
  overflow-y: auto;
  overflow-x: hidden;
  animation: slideUp 0.3s ease;
  box-sizing: border-box;
  margin: 20rpx auto;
  padding: 0;
}

.post-task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.post-task-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.post-task-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.post-task-content {
  padding: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.required {
  color: #fc5c7d;
}

.form-input {
  width: 100%;
  height: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg-main);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-input:focus {
  border-color: var(--primary);
  outline: none;
}

.form-input.error {
  border-color: #fc5c7d;
}

.form-error {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #fc5c7d;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg-main);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--text-primary);
  min-height: 160rpx;
  box-sizing: border-box;
  resize: none;
  transition: border-color 0.2s ease;
}

.form-textarea:focus {
  border-color: var(--primary);
  outline: none;
}

.deadline-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.deadline-input {
  flex: 1;
  padding: 20rpx 24rpx;
  background: var(--bg-main);
  border: 2rpx solid var(--border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.deadline-icon {
  font-size: 32rpx;
}

.deadline-text {
  flex: 1;
  color: var(--text-secondary);
}

.deadline-clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.custom-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1003;
}

.custom-picker-container {
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx;
  width: 100%;
  animation: slideUp 0.3s ease;
}

.custom-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.custom-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.custom-picker-actions {
  display: flex;
  gap: 16rpx;
}

.custom-picker-btn {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
}

.custom-picker-btn.cancel {
  background: var(--border);
  color: var(--text-primary);
}

.custom-picker-btn.confirm {
  background: var(--primary);
  color: #fff;
}

.custom-picker-content {
  display: flex;
  gap: 24rpx;
}

.picker-section {
  flex: 1;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  text-align: center;
}

.date-picker-grid,
.time-picker-grid {
  display: flex;
  gap: 16rpx;
}

.picker-column {
  flex: 1;
  max-height: 400rpx;
  overflow-y: auto;
}

.picker-item {
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.picker-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}

.separator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.separator-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.post-task-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid var(--border);
}

.btn-cancel,
.btn-submit {
  flex: 1;
  padding: 20rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-cancel {
  background: var(--border);
  color: var(--text-primary);
}

.btn-submit {
  background: var(--primary);
  color: #fff;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
