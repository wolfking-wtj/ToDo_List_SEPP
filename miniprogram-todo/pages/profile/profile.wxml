<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info">
      <view class="user-avatar" bindtap="onTapAvatar">
        <image wx:if="{{userInfo.avatar && userInfo.avatar !== '👤' && userInfo.avatar !== '' && userInfo.avatar !== null && !userInfo.avatar.startsWith('wxfile://')}}" class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill" />
        <image wx:elif="{{userInfo.avatar && userInfo.avatar.startsWith('wxfile://')}}" class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-icon">{{'👤'}}</text>
      </view>
      <view class="user-details">
        <view class="user-name">{{userInfo.name}}</view>
        <view class="user-username">{{userInfo.username}}</view>
        <view class="user-level">
          <text class="level-text">Lv.{{userInfo.level}}</text>
          <text class="points-text">{{userInfo.points}} 积分</text>
        </view>
      </view>
      <view class="edit-btn" bindtap="onEditProfile">
        <text class="edit-icon">✏️</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view wx:for="{{menuItems}}" wx:key="id" class="menu-item" bindtap="onTapMenuItem" data-id="{{item.id}}">
      <view class="menu-icon">
        <text class="icon">{{item.icon}}</text>
      </view>
      <view class="menu-info">
        <view class="menu-title">{{item.title}}</view>
        <view class="menu-subtitle">{{item.subtitle}}</view>
      </view>
      <view class="menu-arrow">
        <text class="arrow-icon">➡️</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="onLogout">
    <text class="logout-text">退出登录</text>
  </view>

  <!-- 修改个人信息弹窗 -->
  <view class="modal" wx:if="{{showEditModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">修改个人信息</text>
        <text class="modal-close" bindtap="onCloseModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input class="form-input" placeholder="请输入昵称" value="{{editForm.name}}" bindinput="onNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">用户名</text>
          <input class="form-input" placeholder="请输入用户名" value="{{editForm.username}}" bindinput="onUsernameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">邮箱</text>
          <input class="form-input" placeholder="请输入邮箱" value="{{editForm.email}}" bindinput="onEmailInput" />
        </view>
        <view class="form-item">
          <text class="form-label">头像</text>
          <view class="avatar-upload" bindtap="onChooseAvatar">
            <text class="avatar-upload-icon">📷</text>
            <text class="avatar-upload-text">选择头像</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="onCloseModal">取消</button>
        <button class="btn-save" bindtap="onSaveProfile">保存</button>
      </view>
    </view>
  </view>
</view>