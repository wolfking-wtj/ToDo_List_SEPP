/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: var(--bg-main);
  padding: 32rpx 32rpx 200rpx;
}

.user-section {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  flex-shrink: 0;
}

.avatar-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  object-fit: cover;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.user-username {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.user-level {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.level-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
  background: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.points-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-main);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.edit-btn:active {
  transform: scale(0.9);
  background: var(--primary-light);
}

.edit-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.menu-section {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  border-bottom: 2rpx solid var(--border-light);
  transition: all 0.2s ease;
  gap: 20rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--primary-light);
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--bg-main);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon {
  font-size: 32rpx;
  color: var(--primary);
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 4rpx;
}

.menu-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.3;
}

.menu-arrow {
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.logout-btn {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  text-align: center;
  transition: all 0.2s ease;
}

.logout-btn:active {
  background: var(--danger-light);
}

.logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--danger);
}

/* 修改个人信息弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: white;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  animation: scaleIn 0.3s ease-out;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  cursor: pointer;
  transition: color 0.2s ease;
}

.modal-close:active {
  color: var(--text-primary);
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
  background: white;
}

.form-value {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 16rpx 0;
}

.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius-md);
  background: var(--bg-main);
  cursor: pointer;
  transition: all 0.3s ease;
}

.avatar-upload:active {
  background: var(--primary-light);
  border-color: var(--primary);
}

.avatar-upload-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.avatar-upload-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  border-top: 1rpx solid var(--border);
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-cancel {
  background: var(--bg-main);
  color: var(--text-secondary);
}

.btn-save {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: white;
}

.btn-cancel:active, .btn-save:active {
  transform: scale(0.98);
}

/* 动画 */
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}