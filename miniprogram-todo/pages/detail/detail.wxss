/* pages/detail/detail.wxss - 详情页样式 */

.detail-container {
  min-height: 100vh;
  background: var(--bg-main);
  padding: 32rpx;
}

/* ===== 状态横幅 ===== */
.status-banner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 36rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  animation: fadeInUp 0.35s ease;
}

.status-banner.pending {
  background: linear-gradient(135deg, var(--primary-light), #f0f0ff);
  border-left: 8rpx solid var(--primary);
}

.status-banner.completed {
  background: linear-gradient(135deg, var(--success-light), #e6fff4);
  border-left: 8rpx solid var(--success);
}

.status-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-icon {
  font-size: 48rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 主信息卡片 ===== */
.info-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  animation: fadeInUp 0.4s ease;
}

.priority-badge {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  margin-bottom: 28rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 24rpx;
  word-break: break-all;
}

.detail-title.line-through {
  text-decoration: line-through;
  color: var(--text-muted);
  font-weight: 400;
}

.detail-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  padding: 28rpx;
  background: var(--bg-main);
  border-radius: var(--radius-md);
  margin-bottom: 36rpx;
}

.no-desc {
  color: var(--text-muted);
  font-style: italic;
}

/* 时间信息 */
.time-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  border-top: 2rpx solid var(--border);
  padding-top: 32rpx;
}

.time-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.time-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.time-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.time-value {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ===== 操作区 ===== */
.actions-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  animation: fadeInUp 0.45s ease;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 36rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.action-card:active {
  transform: scale(0.95);
}

.action-card.done {
  background: linear-gradient(135deg, var(--success-light), #dcfce7);
}

.action-card.undo {
  background: linear-gradient(135deg, var(--warning-light), #fef3c7);
}

.action-card.copy-btn {
  background: linear-gradient(135deg, var(--primary-light), #ede9fe);
}

.action-card-icon {
  font-size: 52rpx;
}

.action-card-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

/* ===== 删除按钮 ===== */
.delete-section {
  animation: fadeInUp 0.5s ease;
}

.delete-btn {
  padding: 32rpx;
  text-align: center;
  background: var(--danger-light);
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--danger);
  transition: all 0.2s ease;
}

.delete-btn:active {
  transform: scale(0.98);
  background: #ffe0e6;
}

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 24rpx;
}

.loading-icon {
  font-size: 80rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-muted);
}
