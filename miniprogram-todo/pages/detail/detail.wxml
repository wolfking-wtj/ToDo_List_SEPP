<!-- pages/detail/detail.wxml - 任务详情页模板 -->
<view wx:if="{{todo}}" class="detail-container">

  <!-- ===== 状态横幅 ===== -->
  <view class="status-banner {{todo.completed ? 'completed' : 'pending'}}">
    <view class="status-icon-wrap">
      <text class="status-icon">{{todo.completed ? '✅' : '📌'}}</text>
    </view>
    <view class="status-info">
      <text class="status-label">{{todo.completed ? '已完成' : '进行中'}}</text>
      <text wx:if="{{formattedCompletedAt}}" class="status-time">
        完成于 {{formattedCompletedAt}}
      </text>
    </view>
  </view>

  <!-- ===== 主信息卡片 ===== -->
  <view class="info-card">
    <!-- 优先级徽章 -->
    <view
      class="priority-badge"
      style="color: {{priorityConfig.color}}; background: {{priorityConfig.bg}}"
    >
      {{priorityConfig.icon}} {{priorityConfig.label}}优先级
    </view>

    <!-- 标题 -->
    <view class="detail-title {{todo.completed ? 'line-through' : ''}}">
      {{todo.title}}
    </view>

    <!-- 描述 -->
    <view wx:if="{{todo.desc}}" class="detail-desc">
      {{todo.desc}}
    </view>
    <view wx:else class="detail-desc no-desc">暂无描述</view>

    <!-- 时间信息 -->
    <view class="time-section">
      <view class="time-item">
        <text class="time-icon">📅</text>
        <view>
          <text class="time-label">创建时间</text>
          <text class="time-value">{{formattedCreatedAt}}</text>
        </view>
      </view>
      <view wx:if="{{formattedCompletedAt}}" class="time-item">
        <text class="time-icon">🏁</text>
        <view>
          <text class="time-label">完成时间</text>
          <text class="time-value">{{formattedCompletedAt}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 操作区 ===== -->
  <view class="actions-section">
    <!-- 切换完成状态 -->
    <view
      class="action-card toggle-btn {{todo.completed ? 'undo' : 'done'}}"
      bindtap="onToggle"
    >
      <text class="action-card-icon">{{todo.completed ? '↩️' : '✅'}}</text>
      <text class="action-card-label">{{todo.completed ? '标记未完成' : '标记完成'}}</text>
    </view>

    <!-- 复制标题 -->
    <view class="action-card copy-btn" bindtap="onCopyTitle">
      <text class="action-card-icon">📋</text>
      <text class="action-card-label">复制标题</text>
    </view>
  </view>

  <!-- 删除按钮 -->
  <view class="delete-section">
    <view class="delete-btn" bindtap="onDelete">
      <text>🗑️ 删除任务</text>
    </view>
  </view>

</view>

<!-- 加载中 -->
<view wx:else class="loading-state">
  <text class="loading-icon">⏳</text>
  <text class="loading-text">加载中...</text>
</view>
